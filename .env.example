# Local dev: matches docker-compose.yml
DATABASE_URL=postgres://bumpyride:bumpyride@localhost:5432/bumpyride

# Cloud Run + Cloud SQL (Unix socket) — set in the service's env, not here:
# DATABASE_URL=postgres://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Optional: HTTP port. Cloud Run injects PORT automatically.
PORT=8080
