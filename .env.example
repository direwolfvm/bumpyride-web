# Local dev: matches docker-compose.yml
DATABASE_URL=postgres://bumpyride:bumpyride@localhost:5432/bumpyride

# Cloud Run + Cloud SQL (Unix socket) — set in the service's env, not here:
# DATABASE_URL=postgres://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Optional: HTTP port. Cloud Run injects PORT automatically.
PORT=8080

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string

# Behind Cloud Run / any reverse proxy, set this so cookies use the right host.
# AUTH_URL=https://your-cloud-run-url.run.app

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <AUTH_URL>/api/auth/callback/google
# Leave blank to disable the Google sign-in button.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
